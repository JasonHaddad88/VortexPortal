<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Permissions roadmap: M0 = service+notifications, M1 = camera,
        M2 will add MEDIA_PROJECTION, M3 will declare the
        AccessibilityService.
    -->

    <!-- Foreground service so Android doesn't kill us under Doze. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Service-type permissions (required since Android 14 / API 34). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- Notifications since Android 13 (API 33) need runtime grant. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- M1: camera (Camera2 API). Runtime grant required. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Internet for the inbound direct-WS server (Driver-B3) + the
         outbound hub WS (Driver-B1). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      Driver-B4: native theft-mode ops (replaces the Termux:API path on
      Android).
        - ACCESS_FINE/COARSE_LOCATION  -> LocationOp (LocationManager)
        - RECORD_AUDIO                 -> RecordAudioOp (MediaRecorder)
        - WAKE_LOCK                    -> WakeLockOp (PARTIAL_WAKE_LOCK)
      All three are dangerous (camera/mic/location/wakelock) and need a
      runtime grant; we surface clear error strings if missing.
      FOREGROUND_SERVICE_* siblings are required on Android 14+ when
      the active service-type bitmask includes the corresponding kind.
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- We require *some* camera but don't pin to a specific one (front or
         back) so the APK installs on phones that only have one of them. -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <!-- Optional, not required (so non-mic / no-GPS devices can still install). -->
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <uses-feature android:name="android.hardware.location" android:required="false" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />
    <uses-feature android:name="android.hardware.location.network" android:required="false" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.VortexDriver">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          M2: launches the system MediaProjection consent dialog. Themed
          translucent so the dialog appears to overlay whatever the user
          was looking at. Not exported, only MainActivity launches it.
        -->
        <activity
            android:name=".ScreenSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.VortexDriver.Translucent" />

        <!--
          B1: standalone enrollment — paste an account token + hub URL,
          POST /api/enroll, save device_id+token. Launched from
          MainActivity when Prefs.isEnrolled() is false.
        -->
        <activity
            android:name=".EnrollActivity"
            android:exported="true"
            android:label="@string/enroll_title"
            android:windowSoftInputMode="adjustResize">
            <!--
              B2: deep-link enrollment via QR. The hub renders a QR
              encoding `vortex://enroll?token=…&hub=…&name=…`; scanning
              with the phone camera opens this activity with all fields
              pre-filled and immediately runs /api/enroll. No typing.
              `exported=true` is required for an external intent (the
              camera app) to launch us; we still only act on a parsed
              URI we control end-to-end.
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="vortex" android:host="enroll" />
            </intent-filter>
        </activity>

        <service
            android:name=".DriverService"
            android:exported="false"
            android:foregroundServiceType="dataSync|camera|mediaProjection|microphone|location" />

        <!--
          M3: AccessibilityService for remote touch input. Must be exported
          and protected by BIND_ACCESSIBILITY_SERVICE so the system AND
          ONLY the system can bind us. The user enables this manually via
          Settings, Accessibility, Vortex Driver. There is no programmatic
          way to do it.
        -->
        <service
            android:name=".VortexAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>
</manifest>
