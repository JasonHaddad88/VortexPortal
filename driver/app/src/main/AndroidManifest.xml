<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Permissions roadmap: M0 = service+notifications, M1 = camera,
        M2 will add MEDIA_PROJECTION, M3 will declare the
        AccessibilityService.
    -->

    <!-- Foreground service so Android doesn't kill us under Doze. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Service-type permissions (required since Android 14 / API 34). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <!-- Notifications since Android 13 (API 33) need runtime grant. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- M1: camera (Camera2 API). Runtime grant required. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Internet not strictly needed (we're loopback-only), but having it
         avoids a future manifest churn when we add direct WebSocket support. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- We require *some* camera but don't pin to a specific one (front or
         back) so the APK installs on phones that only have one of them. -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.VortexDriver">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".DriverService"
            android:exported="false"
            android:foregroundServiceType="dataSync|camera" />
    </application>
</manifest>
