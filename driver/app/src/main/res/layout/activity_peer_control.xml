<?xml version="1.0" encoding="utf-8"?>
<!--
  B11.3: native per-device viewer. Three tabs (Screen / Camera / Info)
  rendered via simple state-toggled visibility because TabLayout would
  drag in the entire MaterialComponents Tab API for one screen.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/vortex_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/vortex_surface">

        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/vortex_brand_logo"/>
        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:textColor="@color/vortex_text"
            android:textSize="15sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/conn_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/vortex_text_muted"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/vortex_border"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">
        <Button
            android:id="@+id/tab_screen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/peer_tab_screen"
            android:textColor="@color/vortex_text"
            android:textAllCaps="false"
            android:background="@drawable/vortex_pill_on"/>
        <Button
            android:id="@+id/tab_camera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:text="@string/peer_tab_camera"
            android:textColor="@color/vortex_text_subtle"
            android:textAllCaps="false"
            android:background="@drawable/vortex_pill_off"/>
        <Button
            android:id="@+id/tab_files"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:text="@string/peer_tab_files"
            android:textColor="@color/vortex_text_subtle"
            android:textAllCaps="false"
            android:background="@drawable/vortex_pill_off"/>
        <Button
            android:id="@+id/tab_theft"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:text="@string/peer_tab_theft"
            android:textColor="@color/vortex_text_subtle"
            android:textAllCaps="false"
            android:background="@drawable/vortex_pill_off"/>
        <Button
            android:id="@+id/tab_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/peer_tab_info"
            android:textColor="@color/vortex_text_subtle"
            android:textAllCaps="false"
            android:background="@drawable/vortex_pill_off"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/stage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        android:background="@drawable/vortex_card">

        <!-- Screen / Camera live frame. ImageView for MJPEG (default
             on Camera, fallback on Screen) + SurfaceView for H.264
             native decode (B11.7, Screen-only). Only one is visible
             at a time; PeerControlActivity flips them on the
             stream_start.content_type. Both have the same touch
             listener so input passthrough (B11.6) works either way. -->
        <ImageView
            android:id="@+id/frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="@string/peer_tab_screen"
            android:visibility="gone"/>
        <SurfaceView
            android:id="@+id/frame_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <!-- Info tab: pretty-printed device_info JSON in a scrollable text view. -->
        <ScrollView
            android:id="@+id/info_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/info_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/vortex_text"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"/>
        </ScrollView>

        <!-- B11.8: Theft-mode controls. Four compact cards driving
             the existing B4 ops (location / record_audio /
             camera_capture / keepawake) via PeerClient. -->
        <ScrollView
            android:id="@+id/theft_pane"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Location card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/vortex_card"
                    android:padding="14dp"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/peer_theft_location_title"
                        android:textColor="@color/vortex_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:textAllCaps="true"/>
                    <TextView
                        android:id="@+id/theft_location_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="13sp"
                        android:textColor="@color/vortex_text_muted"
                        android:text="@string/peer_theft_idle"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">
                        <Button
                            android:id="@+id/theft_location_btn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/peer_theft_location_btn"
                            android:textColor="@color/vortex_bg"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            android:background="@drawable/vortex_button_primary"/>
                        <Button
                            android:id="@+id/theft_location_map_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            style="?android:attr/buttonBarButtonStyle"
                            android:text="@string/peer_theft_location_map"
                            android:textColor="@color/vortex_cyan"
                            android:textAllCaps="false"
                            android:visibility="gone"/>
                    </LinearLayout>
                    <!-- B11.15: queue this op for next-online. Hidden
                         visually with no margin until needed; writes
                         a device_commands row keyed by the peer's
                         device_id. -->
                    <Button
                        android:id="@+id/theft_location_queue_btn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        style="?android:attr/buttonBarButtonStyle"
                        android:text="@string/peer_theft_queue_btn"
                        android:textColor="@color/vortex_cyan"
                        android:textAllCaps="false"/>
                </LinearLayout>

                <!-- Audio card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/vortex_card"
                    android:padding="14dp"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/peer_theft_audio_title"
                        android:textColor="@color/vortex_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:textAllCaps="true"/>
                    <RadioGroup
                        android:id="@+id/theft_audio_duration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">
                        <RadioButton
                            android:id="@+id/theft_audio_5s"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 s"
                            android:textColor="@color/vortex_text"
                            android:buttonTint="@color/vortex_cyan"/>
                        <RadioButton
                            android:id="@+id/theft_audio_15s"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="15 s"
                            android:textColor="@color/vortex_text"
                            android:buttonTint="@color/vortex_cyan"
                            android:checked="true"/>
                        <RadioButton
                            android:id="@+id/theft_audio_30s"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="30 s"
                            android:textColor="@color/vortex_text"
                            android:buttonTint="@color/vortex_cyan"/>
                    </RadioGroup>
                    <TextView
                        android:id="@+id/theft_audio_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="13sp"
                        android:textColor="@color/vortex_text_muted"
                        android:text="@string/peer_theft_idle"/>
                    <Button
                        android:id="@+id/theft_audio_btn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/peer_theft_audio_btn"
                        android:textColor="@color/vortex_bg"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/vortex_button_primary"/>
                </LinearLayout>

                <!-- Camera card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/vortex_card"
                    android:padding="14dp"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/peer_theft_camera_title"
                        android:textColor="@color/vortex_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:textAllCaps="true"/>
                    <RadioGroup
                        android:id="@+id/theft_camera_facing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">
                        <RadioButton
                            android:id="@+id/theft_camera_back"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/peer_theft_camera_back"
                            android:textColor="@color/vortex_text"
                            android:buttonTint="@color/vortex_cyan"
                            android:checked="true"/>
                        <RadioButton
                            android:id="@+id/theft_camera_front"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="@string/peer_theft_camera_front"
                            android:textColor="@color/vortex_text"
                            android:buttonTint="@color/vortex_cyan"/>
                    </RadioGroup>
                    <TextView
                        android:id="@+id/theft_camera_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="13sp"
                        android:textColor="@color/vortex_text_muted"
                        android:text="@string/peer_theft_idle"/>
                    <Button
                        android:id="@+id/theft_camera_btn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/peer_theft_camera_btn"
                        android:textColor="@color/vortex_bg"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/vortex_button_primary"/>
                </LinearLayout>

                <!-- B11.15: Find-my-phone card. Plays the system alarm
                     ringtone on the peer (max alarm volume) for 10 s.
                     Both real-time and queue-for-next-online variants.
                     Useful for "where did I leave it" and theft
                     scenarios alike. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/vortex_card"
                    android:padding="14dp"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/peer_theft_sound_title"
                        android:textColor="@color/vortex_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:textAllCaps="true"/>
                    <TextView
                        android:id="@+id/theft_sound_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="13sp"
                        android:textColor="@color/vortex_text_muted"
                        android:text="@string/peer_theft_idle"/>
                    <Button
                        android:id="@+id/theft_sound_btn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/peer_theft_sound_btn"
                        android:textColor="@color/vortex_bg"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/vortex_button_primary"/>
                    <Button
                        android:id="@+id/theft_sound_queue_btn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        style="?android:attr/buttonBarButtonStyle"
                        android:text="@string/peer_theft_queue_btn"
                        android:textColor="@color/vortex_cyan"
                        android:textAllCaps="false"/>
                </LinearLayout>

                <!-- Wake-lock card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/vortex_card"
                    android:padding="14dp"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/peer_theft_wake_title"
                        android:textColor="@color/vortex_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:textAllCaps="true"/>
                    <TextView
                        android:id="@+id/theft_wake_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="13sp"
                        android:textColor="@color/vortex_text_muted"
                        android:text="@string/peer_theft_wake_idle"/>
                    <Button
                        android:id="@+id/theft_wake_btn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/peer_theft_wake_on"
                        android:textColor="@color/vortex_bg"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/vortex_button_primary"/>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- B11.5: Files tab. Breadcrumb path + Up button + scrollable
             list. Rows inflated from row_file.xml. -->
        <LinearLayout
            android:id="@+id/files_pane"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@color/vortex_surface_2">
                <Button
                    android:id="@+id/files_up_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="36dp"
                    android:layout_marginEnd="8dp"
                    style="?android:attr/buttonBarButtonStyle"
                    android:text="@string/peer_files_up"
                    android:textColor="@color/vortex_cyan"
                    android:textAllCaps="false"/>
                <TextView
                    android:id="@+id/files_path"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/vortex_text_subtle"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:ellipsize="start"
                    android:singleLine="true"
                    android:text="/"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vortex_border"/>
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <LinearLayout
                    android:id="@+id/files_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>
        </LinearLayout>

        <!-- Initial placeholder + connection status. -->
        <LinearLayout
            android:id="@+id/placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/vortex_cyan"/>
            <TextView
                android:id="@+id/placeholder_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/vortex_text_muted"
                android:textSize="13sp"
                android:gravity="center"
                android:text="@string/peer_connecting"/>
        </LinearLayout>

        <Button
            android:id="@+id/camera_flip_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="14dp"
            style="?android:attr/buttonBarButtonStyle"
            android:text="@string/peer_camera_flip"
            android:textColor="@color/vortex_cyan"
            android:textAllCaps="false"
            android:background="@drawable/vortex_pill_off"
            android:visibility="gone"/>

        <!-- B11.6: hardware-key row floats at the bottom of the screen
             stage. Shown only on the Screen tab so the user can drive
             Back / Home / Recents on the peer phone. Frame is the
             touch-input target itself, so this row needs clickable
             children to stop the gestures from leaking through. -->
        <LinearLayout
            android:id="@+id/sys_keys"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_margin="14dp"
            android:orientation="horizontal"
            android:padding="6dp"
            android:background="@drawable/vortex_pill_on"
            android:visibility="gone">
            <Button
                android:id="@+id/key_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                style="?android:attr/buttonBarButtonStyle"
                android:text="@string/peer_key_back"
                android:textColor="@color/vortex_text"
                android:textAllCaps="false"/>
            <Button
                android:id="@+id/key_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                style="?android:attr/buttonBarButtonStyle"
                android:text="@string/peer_key_home"
                android:textColor="@color/vortex_text"
                android:textAllCaps="false"/>
            <Button
                android:id="@+id/key_recents"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                style="?android:attr/buttonBarButtonStyle"
                android:text="@string/peer_key_recents"
                android:textColor="@color/vortex_text"
                android:textAllCaps="false"/>
            <!-- B11.12: push-to-talk. Hold the button to encode mic
                 audio and stream it to the peer's speakers; release
                 to stop. Pill background changes red while talking. -->
            <Button
                android:id="@+id/key_mic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                style="?android:attr/buttonBarButtonStyle"
                android:text="@string/peer_mic_hold"
                android:textColor="@color/vortex_text"
                android:textAllCaps="false"/>
            <!-- B11.13: audio-only toggle. When checked, the Screen
                 tab opens audio_stream (no video encoded on the peer,
                 ~16 KB/s) instead of screen_stream. Toggles take
                 effect the next time the tab opens a stream. -->
            <CheckBox
                android:id="@+id/key_audio_only"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="10dp"
                android:text="@string/peer_audio_only"
                android:textColor="@color/vortex_text"
                android:textAllCaps="false"
                android:buttonTint="@color/vortex_cyan"/>
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/error_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="12dp"
        android:textColor="@color/vortex_danger"
        android:textSize="12sp"
        android:visibility="gone"/>
</LinearLayout>
