<?xml version="1.0" encoding="utf-8"?>
<!--
  B11.3: native per-device viewer. Three tabs (Screen / Camera / Info)
  rendered via simple state-toggled visibility because TabLayout would
  drag in the entire MaterialComponents Tab API for one screen.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/vortex_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/vortex_surface">

        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/vortex_brand_logo"/>
        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:textColor="@color/vortex_text"
            android:textSize="15sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/conn_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/vortex_text_muted"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/vortex_border"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">
        <Button
            android:id="@+id/tab_screen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/peer_tab_screen"
            android:textColor="@color/vortex_text"
            android:textAllCaps="false"
            android:background="@drawable/vortex_pill_on"/>
        <Button
            android:id="@+id/tab_camera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:text="@string/peer_tab_camera"
            android:textColor="@color/vortex_text_subtle"
            android:textAllCaps="false"
            android:background="@drawable/vortex_pill_off"/>
        <Button
            android:id="@+id/tab_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/peer_tab_info"
            android:textColor="@color/vortex_text_subtle"
            android:textAllCaps="false"
            android:background="@drawable/vortex_pill_off"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/stage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        android:background="@drawable/vortex_card">

        <!-- Screen / Camera live frame. ImageView for the MJPEG path
             (B11.4 will add a SurfaceView + MediaCodec for H.264). -->
        <ImageView
            android:id="@+id/frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="@string/peer_tab_screen"
            android:visibility="gone"/>

        <!-- Info tab: pretty-printed device_info JSON in a scrollable text view. -->
        <ScrollView
            android:id="@+id/info_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/info_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/vortex_text"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"/>
        </ScrollView>

        <!-- Initial placeholder + connection status. -->
        <LinearLayout
            android:id="@+id/placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/vortex_cyan"/>
            <TextView
                android:id="@+id/placeholder_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/vortex_text_muted"
                android:textSize="13sp"
                android:gravity="center"
                android:text="@string/peer_connecting"/>
        </LinearLayout>

        <Button
            android:id="@+id/camera_flip_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="14dp"
            style="?android:attr/buttonBarButtonStyle"
            android:text="@string/peer_camera_flip"
            android:textColor="@color/vortex_cyan"
            android:textAllCaps="false"
            android:background="@drawable/vortex_pill_off"
            android:visibility="gone"/>
    </FrameLayout>

    <TextView
        android:id="@+id/error_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="12dp"
        android:textColor="@color/vortex_danger"
        android:textSize="12sp"
        android:visibility="gone"/>
</LinearLayout>
