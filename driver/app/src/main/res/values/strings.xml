    <!-- B11: direct Turso backend (no hub server). The APK reads/writes
         the same users + devices tables the webapp uses; setup is just
         pasting the Turso URL and a token. -->
    <string name="setup_title">Connect your database</string>
    <string name="setup_subtitle">Vortex stores accounts and devices in a Turso database that every device of yours can read directly. Paste your database URL and a token to continue — no server in the middle.</string>
    <string name="setup_label_url">Database URL</string>
    <string name="setup_hint_url">libsql://your-db.turso.io</string>
    <string name="setup_label_token">Database token</string>
    <string name="setup_hint_token">paste the JWT from `turso db tokens create`</string>
    <string name="setup_btn_save">Save &amp; continue</string>
    <string name="setup_btn_test">Test connection</string>
    <string name="setup_help">Tip: create a free Turso database at turso.tech, then run `turso db tokens create &lt;db&gt;` to mint a token. Both values are stored only on this phone (private SharedPreferences).</string>

    <!-- B11.4: optional relay URL for cross-network control. -->
    <string name="setup_label_relay">Relay server URL (optional)</string>
    <string name="setup_hint_relay">Leave blank to auto-discover</string>
    <string name="setup_relay_help">Without a relay, devices can only control each other on the SAME Wi-Fi. To control across networks, run a Vortex hub somewhere reachable (Cloudflare Tunnel, $4/mo VM, etc.) pointed at the SAME database above.\n\nLeave this blank to AUTO-DISCOVER from the database — any running hub publishes its current URL there, so a rotating Cloudflare quick-tunnel URL on a Termux self-host just works. Fill it in only to pin a specific URL.</string>
    <string name="peer_falling_back_to_relay">Direct LAN connect failed — switching to relay…</string>
    <string name="peer_connect_failed_no_relay">Couldn\'t reach this device on the LAN, and no relay URL is configured. Add one in Setup to control devices on other networks. (Direct error: %1$s)</string>

