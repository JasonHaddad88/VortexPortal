<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VortexDriver" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Match the hub's purple/cyan palette so the APK feels like the same product. -->
        <item name="colorPrimary">#A855F7</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#67E8F9</item>
        <item name="colorOnSecondary">#06060A</item>

        <item name="android:statusBarColor">#06060A</item>
        <item name="android:navigationBarColor">#06060A</item>
        <item name="android:windowBackground">#06060A</item>
    </style>

    <!-- Used by ScreenSetupActivity. Fully transparent + no animation so
         the system MediaProjection consent dialog appears to overlay
         whatever the user was looking at. -->
    <style name="Theme.VortexDriver.Translucent" parent="Theme.VortexDriver">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!--
      B10: webapp-matching field-label + input styles. The label is the
      small uppercase letter-spaced text the webapp puts above its
      `<input>` fields; the input is a dark-surface box with a faint
      purple border that picks up a cyan glow on focus.
    -->
    <style name="VortexLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:text">Label</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.10</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/vortex_text_subtle</item>
    </style>

    <style name="VortexInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:background">@drawable/vortex_input</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/vortex_text</item>
        <item name="android:textColorHint">@color/vortex_text_muted</item>
        <item name="android:textSize">15sp</item>
    </style>
</resources>
