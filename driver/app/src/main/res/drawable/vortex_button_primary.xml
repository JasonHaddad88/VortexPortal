<?xml version="1.0" encoding="utf-8"?>
<!-- B10: primary action button. Purple->cyan gradient like the webapp's
     main-action buttons (Sign In, Continue, etc.). Pressed state dims
     via a translucent black overlay layered on the gradient. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="0"
                        android:startColor="@color/vortex_purple"
                        android:endColor="@color/vortex_cyan" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#33000000" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/vortex_surface_2" />
            <stroke android:width="1dp" android:color="@color/vortex_border" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="@color/vortex_purple"
                android:endColor="@color/vortex_cyan" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
