<?xml version="1.0" encoding="utf-8"?>
<!-- B10: webapp `.card` look. Dark surface, faint purple border,
     12dp radius. Drop-shadow not used here (Android elevation is
     more reliable than a fake glow on dark themes). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/vortex_surface" />
    <stroke android:width="1dp" android:color="@color/vortex_border" />
    <corners android:radius="12dp" />
</shape>
