<?xml version="1.0" encoding="utf-8"?>
<!-- B10: input field. Slightly lighter than the card so it pops. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/vortex_surface_2" />
            <stroke android:width="1dp" android:color="@color/vortex_cyan" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/vortex_surface_2" />
            <stroke android:width="1dp" android:color="@color/vortex_border" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
